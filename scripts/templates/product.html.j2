<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ cover.title }} — Soothemade Notes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=Caveat:wght@400;600&display=swap" rel="stylesheet">
  <style>
    @page {
      size: {{ page_size }};
      margin: 0.85in 0.85in 1.0in 0.85in;
      @bottom-left {
        content: "soothemade.com/notes";
        font-family: 'Inter', sans-serif;
        color: #B8AC9A;
        font-size: 8.5pt;
        letter-spacing: 0.08em;
      }
      @bottom-center {
        content: "— Soothemade —";
        font-family: 'Caveat', cursive;
        color: #B8AC9A;
        font-size: 11pt;
      }
      @bottom-right {
        content: counter(page);
        font-family: 'Inter', sans-serif;
        color: #B8AC9A;
        font-size: 9pt;
        letter-spacing: 0.04em;
      }
    }
    @page :first {
      margin: 0;
      @bottom-left   { content: ""; }
      @bottom-center { content: ""; }
      @bottom-right  { content: ""; }
    }
    @page colophon {
      margin: 0;
      @bottom-left   { content: ""; }
      @bottom-center { content: ""; }
      @bottom-right  { content: ""; }
    }
  </style>
</head>
<body>

  {# ───────── COVER ───────── #}
  <section class="cover">
    <div class="cover-top">
      <svg class="cover-mark" width="105" height="78" viewBox="0 0 140 100" fill="none" stroke="#8C9B7A" stroke-width="1.2" aria-hidden="true">
        {# central stem #}
        <path d="M70 96 L70 14" stroke-linecap="round" />
        {# top bud #}
        <circle cx="70" cy="14" r="2.8" fill="#8C9B7A" stroke="none" />
        {# left leaves #}
        <path d="M70 26 Q 50 28, 42 44 Q 60 40, 70 38 Z" />
        <path d="M70 44 Q 46 46, 36 64 Q 60 58, 70 56 Z" />
        <path d="M70 62 Q 50 64, 44 78 Q 62 74, 70 72 Z" />
        {# right leaves #}
        <path d="M70 30 Q 90 32, 98 48 Q 80 44, 70 42 Z" />
        <path d="M70 48 Q 94 50, 104 68 Q 80 62, 70 60 Z" />
        <path d="M70 66 Q 90 68, 96 82 Q 78 78, 70 76 Z" />
      </svg>

      {% if cover.code or cover.specs %}
        <div class="cover-meta">
          {% if cover.code %}<span>{{ cover.code }}</span>{% endif %}
          {% if cover.code and cover.specs %}<span class="dot">·</span>{% endif %}
          {% if cover.specs %}<span>{{ cover.specs }}</span>{% endif %}
        </div>
      {% endif %}

      <h1 class="cover-title">{{ cover.title }}</h1>

      {% if cover.subtitle %}
        <p class="cover-subtitle">{{ cover.subtitle }}</p>
      {% endif %}

      <div class="cover-divider"></div>

      <div class="cover-brand">
        <div class="cover-brand-mark">Soothemade <em>Notes</em></div>
        <div class="cover-brand-line">A small apothecary of printables · made slowly</div>
      </div>
    </div>

    {% if cover.ymyl %}
      <div class="cover-bottom">
        <div class="cover-ymyl">
          A planning and tracking tool · not medical advice
        </div>
      </div>
    {% endif %}
  </section>

  {# ───────── BODY ───────── #}
  <section class="body">
    {{ body | safe }}
  </section>

  {# ───────── COLOPHON ───────── #}
  <section class="colophon">
    <div class="colophon-inner">
      <svg class="colophon-mark" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M10 50 Q 30 10, 50 50 Q 30 30, 10 50 Z M30 14 L 30 48" stroke-linecap="round" />
      </svg>
      <div class="colophon-brand">Soothemade <em>Notes</em></div>
      <p class="colophon-promise">
        Made for the version of you no one tells you about — the one at four in the morning, the one in the parking lot, the one who doesn't recognize her own week.
      </p>
      <div class="colophon-url">notes.soothemade.com</div>
      <div class="colophon-fine">
        Personal use only. Not for redistribution.<br/>
        © 2026 Soothemade · made slowly, in plain language
      </div>
    </div>
  </section>

</body>
</html>
