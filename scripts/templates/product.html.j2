<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ cover.title }} — Soothemade Notes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=Caveat:wght@400;600&display=swap" rel="stylesheet">
  <style>
    @page {
      size: {{ page_size }};
      margin: 0.85in 0.85in 1.0in 0.85in;
      background: #F5EFE6;
      @bottom-left {
        content: "notes.soothemade.com";
        font-family: 'Inter', sans-serif;
        color: #B8AC9A;
        font-size: 8.5pt;
        letter-spacing: 0.08em;
      }
      @bottom-center {
        content: "Soothemade";
        font-family: 'Caveat', cursive;
        color: #B8AC9A;
        font-size: 12pt;
      }
      @bottom-right {
        content: counter(page);
        font-family: 'Inter', sans-serif;
        color: #B8AC9A;
        font-size: 9pt;
        letter-spacing: 0.04em;
      }
    }
    @page :first {
      margin: 0;
      @bottom-left   { content: ""; }
      @bottom-center { content: ""; }
      @bottom-right  { content: ""; }
    }
    @page colophon {
      margin: 0;
      @bottom-left   { content: ""; }
      @bottom-center { content: ""; }
      @bottom-right  { content: ""; }
    }
  </style>
</head>
<body>

  {# ───────── COVER ───────── #}
  <section class="cover">
    <div class="cover-top">
      <svg class="cover-mark" viewBox="370 125 60 95" fill="none" aria-hidden="true">
        <path d="M 400 215 Q 397 175 401 130" stroke="#8C9B7A" stroke-width="2.4" stroke-linecap="round" />
        <ellipse cx="386" cy="190" rx="11" ry="4" fill="#8C9B7A" transform="rotate(-45 386 190)"/>
        <ellipse cx="414" cy="160" rx="11" ry="4" fill="#8C9B7A" transform="rotate(45 414 160)"/>
      </svg>

      {% if cover.code or cover.specs %}
        <div class="cover-meta">
          {% if cover.code %}<span>{{ cover.code }}</span>{% endif %}
          {% if cover.code and cover.specs %}<span class="dot">·</span>{% endif %}
          {% if cover.specs %}<span>{{ cover.specs }}</span>{% endif %}
        </div>
      {% endif %}

      <h1 class="cover-title">{{ cover.title }}</h1>

      {% if cover.subtitle %}
        <p class="cover-subtitle">{{ cover.subtitle }}</p>
      {% endif %}

      <div class="cover-divider"></div>

      <div class="cover-brand">
        <div class="cover-brand-mark"><span class="brand-name">Soothemade</span> <em>Notes</em></div>
        <div class="cover-brand-line">A small apothecary of printables · made slowly</div>
      </div>
    </div>

    {% if cover.ymyl %}
      <div class="cover-bottom">
        <div class="cover-ymyl">
          A planning and tracking tool · not medical advice
        </div>
      </div>
    {% endif %}
  </section>

  {# ───────── BODY ───────── #}
  <section class="body">
    {{ body | safe }}
  </section>

  {# ───────── COLOPHON ───────── #}
  <section class="colophon">
    <div class="colophon-inner">
      <svg class="colophon-mark" viewBox="370 125 60 95" fill="none" stroke="currentColor" aria-hidden="true">
        <path d="M 400 215 Q 397 175 401 130" stroke-width="2.4" stroke-linecap="round" />
        <ellipse cx="386" cy="190" rx="11" ry="4" fill="currentColor" stroke="none" transform="rotate(-45 386 190)"/>
        <ellipse cx="414" cy="160" rx="11" ry="4" fill="currentColor" stroke="none" transform="rotate(45 414 160)"/>
      </svg>
      <div class="colophon-brand"><span class="brand-name">Soothemade</span> <em>Notes</em></div>
      <p class="colophon-promise">
        Made for the version of you no one tells you about, the one at four in the morning, the one in the parking lot, the one who doesn't recognize her own week.
      </p>
      <div class="colophon-url">notes.soothemade.com</div>
      <div class="colophon-fine">
        Personal use only. Not for redistribution.<br/>
        © 2026 Soothemade · made slowly, in plain language
      </div>
    </div>
  </section>

</body>
</html>
