---
interface Post {
  href: string;
  category: string;
  readTime: string;
  title: string;
  blurb: string;
}
interface Props {
  title?: string;
  titleAccent?: string;
  allHref?: string;
  posts: Post[];
}
const {
  title = 'Letters from the studio.',
  titleAccent,
  allHref = '/journal',
  posts,
} = Astro.props;
---
<section class="letters">
  <div class="letters-head">
    <div>
      <div class="eyebrow-mark">— Letters from the studio —</div>
      <h2>
        {title}{titleAccent && (<>{' '}<em>{titleAccent}</em></>)}
      </h2>
    </div>
    <a class="more" href={allHref}>All letters →</a>
  </div>
  <div class="letters-list">
    {posts.map((p) => (
      <article>
        <a href={p.href}>
          <div class="meta">{p.category} · {p.readTime}</div>
          <div class="body">
            <h3>{p.title}</h3>
            <p>{p.blurb}</p>
          </div>
          <span class="arrow">→</span>
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  .letters {
    padding: 80px var(--sp-7);
    background: var(--surface);
  }
  .letters-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    margin-bottom: 32px;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .eyebrow-mark {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
  }
  .letters-head h2 {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 300;
    margin: 0;
    line-height: 1.2;
    color: var(--ink);
  }
  .letters-head h2 em { font-style: italic; color: var(--accent); }
  .letters-head .more {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
  }
  .letters-head .more:hover { color: var(--accent); border-color: var(--accent); }

  .letters-list { display: flex; flex-direction: column; }
  .letters-list article {
    border-top: 1px solid var(--rule);
  }
  .letters-list article:last-child { border-bottom: 1px solid var(--rule); }
  .letters-list article a {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 32px;
    padding: 22px 0;
    align-items: baseline;
    color: var(--ink);
    transition: background var(--t-fast) var(--ease);
  }
  .letters-list article a:hover { background: var(--hover); }
  .meta {
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .body { min-width: 0; }
  h3 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    margin: 0 0 6px;
    line-height: 1.25;
  }
  p {
    margin: 0;
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 540px;
  }
  .arrow {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--accent);
  }

  @media (max-width: 880px) {
    .letters { padding: 56px var(--sp-5); }
    .letters-list article a { grid-template-columns: 1fr; gap: 6px; padding: 18px 0; }
    .arrow { display: none; }
  }
</style>
