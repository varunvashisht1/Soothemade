---
interface Props {
  heading?: string;
  headingAccent?: string;
  body?: string;
  action?: string;
}
const {
  heading = 'One letter, sometimes two,',
  headingAccent = 'a month.',
  body = 'The newsletter goes out when the weather allows, never as a campaign. When a room opens, you’ll be the first to know.',
  action = 'https://notes.soothemade.com/api/subscribe',
} = Astro.props;
---
<section class="newsletter">
  <div class="eyebrow-mark">— if you’d like to stay in touch —</div>
  <h2>{heading} <em>{headingAccent}</em></h2>
  <p>{body}</p>
  <form method="POST" action={action}>
    <label class="visually-hidden" for="newsletter-email">Your email</label>
    <input
      id="newsletter-email"
      type="email"
      name="email"
      placeholder="your address"
      autocomplete="email"
      required
    />
    <input type="hidden" name="source" value="umbrella" />
    <button type="submit">Leave it</button>
  </form>
  <div class="fine">Unsubscribe whenever · we never share addresses</div>
</section>

<style>
  .newsletter {
    background:
      radial-gradient(ellipse 700px 400px at 50% 30%, rgba(212, 165, 72, 0.18), transparent 65%),
      linear-gradient(170deg, var(--apo-tile-news-1) 0%, var(--apo-tile-news-2) 60%, var(--apo-tile-news-3) 100%);
    padding: 104px var(--sp-7);
    text-align: center;
    color: var(--apo-paper);
  }
  .eyebrow-mark {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-soft);
    margin-bottom: 14px;
  }
  h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 34px;
    margin: 0 0 14px;
    color: var(--apo-paper);
    font-weight: 300;
    line-height: 1.2;
  }
  h2 em { color: var(--accent-soft); }
  p {
    color: var(--apo-paper-dim);
    margin: 0 auto 32px;
    max-width: 480px;
    font-size: 15px;
    line-height: 1.65;
  }
  form {
    display: flex;
    max-width: 460px;
    margin: 0 auto;
  }
  input[type="email"] {
    flex: 1;
    border: 1px solid var(--apo-paper);
    border-right: none;
    background: transparent;
    padding: 14px 16px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--apo-paper);
    outline: none;
  }
  input::placeholder { color: var(--apo-paper-faint); }
  button {
    border: 1px solid var(--apo-paper);
    background: var(--apo-paper);
    color: var(--apo-tile-news-1);
    padding: 0 24px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
    font-weight: 500;
  }
  button:hover { background: var(--accent); border-color: var(--accent); color: var(--apo-paper); }
  .fine {
    color: var(--apo-paper-faint);
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--ls-wide);
    margin-top: 20px;
  }
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
  @media (max-width: 880px) {
    .newsletter { padding: 72px var(--sp-5); }
    h2 { font-size: 26px; }
  }
</style>
