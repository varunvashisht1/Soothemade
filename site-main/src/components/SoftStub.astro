---
interface Props {
  eyebrow: string;
  heading: string;
  body: string;
  backHref?: string;
  backLabel?: string;
}
const {
  eyebrow,
  heading,
  body,
  backHref = '/shop',
  backLabel = 'visit the catalog instead →',
} = Astro.props;
---
<section class="stub">
  <div class="eyebrow">{eyebrow}</div>
  <h1>{heading}</h1>
  <p>{body}</p>
  <a class="back" href={backHref}>{backLabel}</a>
</section>

<style>
  .stub {
    max-width: 640px;
    margin: 0 auto;
    padding: 120px var(--sp-7) 140px;
    text-align: center;
  }
  .eyebrow {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: 48px;
    margin: 0 0 22px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }
  p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 0 32px;
  }
  .back {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    font-size: 17px;
  }
  .back:hover { color: var(--accent); border-color: var(--accent); }
  @media (max-width: 880px) {
    .stub { padding: 80px var(--sp-5) 100px; }
    h1 { font-size: 34px; }
    p { font-size: 17px; }
  }
</style>
