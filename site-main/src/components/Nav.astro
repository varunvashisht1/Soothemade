---
/* Nav has two modes:
   - `default` (interior pages): cream background, dark text, regular flow at top.
   - `overlay` (home, over the dark hero): transparent, positioned absolutely
     over the hero, light text. */

interface Props { variant?: 'default' | 'overlay'; }
const { variant = 'default' } = Astro.props;

const links = [
  { href: '/lines', label: 'Rooms' },
  { href: 'https://notes.soothemade.com', label: 'Notes', external: true },
  { href: '/journal', label: 'Journal' },
  { href: '/about', label: 'About' },
];
---
<nav class:list={['topnav', variant]}>
  <a href="/" class="logo" aria-label="Soothemade — home">
    <svg class="sprig" viewBox="370 125 60 95" fill="none" width="20" height="32" aria-hidden="true">
      <path d="M 400 215 Q 397 175 401 130" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
      <ellipse cx="386" cy="190" rx="11" ry="4" fill="currentColor" transform="rotate(-45 386 190)"/>
      <ellipse cx="414" cy="160" rx="11" ry="4" fill="currentColor" transform="rotate(45 414 160)"/>
    </svg>
    <span>Soothemade</span>
  </a>
  <div class="links">
    {links.map((l) => (
      l.external
        ? <a href={l.href} class="ext" rel="noopener">{l.label}</a>
        : <a href={l.href}>{l.label}</a>
    ))}
  </div>
  <a href="/newsletter" class="cta">Letter</a>
</nav>

<style>
  .topnav {
    padding: 22px var(--sp-7);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-5);
  }
  .topnav.default { border-bottom: 1px solid var(--rule); }
  .topnav.overlay {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    background: transparent;
    border-bottom: none;
  }
  .logo {
    font-family: var(--font-script);
    font-size: 32px;
    line-height: 1;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo .sprig {
    flex-shrink: 0;
    align-self: center;
  }
  .topnav.default .logo { color: var(--ink); }
  .topnav.default .logo .sprig { color: var(--accent-soft); }
  .topnav.overlay .logo { color: var(--apo-paper); }
  .topnav.overlay .logo .sprig { color: var(--accent-soft); }

  .links {
    display: flex;
    gap: 28px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
  }
  .topnav.default .links a { color: var(--ink-soft); }
  .topnav.default .links a:hover { color: var(--accent); }
  .topnav.overlay .links a { color: var(--apo-paper-dim); }
  .topnav.overlay .links a:hover { color: var(--accent-soft); }

  .cta {
    border: 1px solid currentColor;
    padding: 7px 14px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    transition: background var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
  }
  .topnav.default .cta { color: var(--ink); border-color: var(--rule-strong); }
  .topnav.default .cta:hover { background: var(--ink); color: var(--surface); border-color: var(--ink); }
  .topnav.overlay .cta { color: var(--apo-paper); border-color: var(--apo-paper-dim); }
  .topnav.overlay .cta:hover { background: var(--apo-paper); color: var(--ink); border-color: var(--apo-paper); }

  @media (max-width: 880px) {
    .topnav { flex-wrap: wrap; padding: 18px var(--sp-5); gap: 12px; }
    .links { order: 3; flex-basis: 100%; justify-content: center; gap: 20px; }
  }
</style>
