---
import { lines } from '~/data/lines';

interface Props {
  /** When true, full-page layout (used on /lines). When false, compact polaroid grid (home). */
  detailed?: boolean;
}
const { detailed = false } = Astro.props;

/* Map line ids to room-tile gradient classes for the polaroid backs.
   Notes always live, others use the Apothecary "warm-black undertone" set. */
const roomClass: Record<string, string> = {
  notes: 'live',
  kitchen: 'r-kitchen',
  studio: 'r-studio',
  field: 'r-field',
};
---
<section class={`rooms-section ${detailed ? 'detailed' : ''}`}>
  <div class="rooms-head">
    <div>
      <div class="eyebrow-mark">— A small house, with rooms —</div>
      <h2>One room <em>open</em>. Three being built.</h2>
    </div>
  </div>
  <div class="polaroid-grid">
    {lines.map((line, i) => (
      <article class={`polaroid ${roomClass[line.id] ?? ''}`}>
        {line.status === 'live' ? (
          <a class="photo" href={line.href} rel="noopener">
            <span class="room-stamp">{line.name}</span>
          </a>
        ) : (
          <div class="photo"><span class="room-stamp">{line.name}</span></div>
        )}
        <div class="caption">
          <div class="meta">
            <span class="num">№ {['i','ii','iii','iv','v','vi'][i] ?? i+1}</span>
            <span class="status">{line.status === 'live' ? 'Open today' : 'In the workshop'}</span>
          </div>
          <div class="name">Soothemade <em>{line.name}</em></div>
          <div class="for">for {line.audience}</div>
          <p class="desc">{detailed ? line.descLong : line.descShort}</p>
          {line.status === 'live' ? (
            <a class="visit" href={line.href} rel="noopener">Visit {line.name.toLowerCase()} ↗</a>
          ) : (
            <a class="visit quiet" href="/newsletter">Hear when it opens</a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .rooms-section {
    padding: 96px var(--sp-7) 112px;
    background:
      radial-gradient(ellipse 900px 500px at 70% 30%, rgba(122, 138, 101, 0.16), transparent 60%),
      linear-gradient(170deg, var(--apo-tile-rooms-1) 0%, var(--apo-tile-rooms-2) 60%, var(--apo-tile-rooms-3) 100%);
    color: var(--apo-paper);
  }
  .rooms-section.detailed { padding: 24px var(--sp-7) 80px; }

  .rooms-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    padding: 0 0 32px;
    border-bottom: 1px solid var(--apo-rule-light);
    margin: 0 0 48px;
  }
  .eyebrow-mark {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-soft);
    margin-bottom: 8px;
  }
  .rooms-head h2 {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 300;
    margin: 0;
    letter-spacing: var(--ls-tight);
    line-height: 1.1;
    color: var(--apo-paper);
  }
  .rooms-head h2 em { font-style: italic; color: var(--accent-soft); font-weight: 300; }

  .polaroid-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .polaroid {
    background: var(--apo-paper);
    padding: 14px 14px 24px;
    transition: transform var(--t-base) var(--ease);
  }
  .polaroid:nth-child(odd) { transform: rotate(-0.6deg); }
  .polaroid:nth-child(even) { transform: rotate(0.4deg); }
  .polaroid:nth-child(3n) { transform: rotate(-0.3deg); }
  .polaroid:hover { transform: rotate(0) translateY(-4px); }

  .polaroid .photo {
    display: block;
    aspect-ratio: 4 / 5;
    position: relative;
    overflow: hidden;
  }
  .polaroid.live .photo {
    background: linear-gradient(160deg, #3d251a 0%, var(--apo-tile-notes) 60%, #1a0f0b 100%);
  }
  .polaroid.r-kitchen .photo {
    background: linear-gradient(160deg, #3d322c 0%, var(--apo-tile-kitchen) 60%, #1a1410 100%);
  }
  .polaroid.r-studio .photo {
    background: linear-gradient(160deg, #2a3528 0%, var(--apo-tile-studio) 60%, #0e160c 100%);
  }
  .polaroid.r-field .photo {
    background: linear-gradient(160deg, #18140e 0%, var(--apo-tile-field) 55%, #030302 100%);
  }
  .polaroid .photo::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 30%, rgba(184, 134, 42, 0.12), transparent 55%),
      radial-gradient(ellipse at 75% 80%, rgba(0,0,0,0.28), transparent 55%);
  }
  .polaroid .room-stamp {
    position: absolute;
    bottom: 18px;
    left: 18px;
    z-index: 2;
    color: var(--accent-soft);
    font-family: var(--font-script);
    font-size: 38px;
    line-height: 0.9;
    font-weight: 500;
  }
  .polaroid.live .room-stamp { color: var(--apo-paper); }

  .polaroid .caption { padding: 14px 4px 0; }
  .polaroid .caption .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .polaroid .caption .num {
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .polaroid .caption .status {
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .polaroid.live .caption .status { color: var(--accent); }
  .polaroid .caption .name {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 400;
    margin: 0 0 4px;
    color: var(--ink);
  }
  .polaroid .caption .name em { font-style: italic; color: var(--accent); }
  .polaroid .caption .for {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0 0 8px;
  }
  .polaroid .caption .desc {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .polaroid .caption .visit {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease);
  }
  .polaroid.live .caption .visit { color: var(--accent); border-color: var(--accent); }
  .polaroid .caption .visit.quiet { color: var(--ink-faint); border-color: var(--ink-faint); }
  .polaroid .caption .visit:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 980px) {
    .rooms-section { padding: 40px var(--sp-5) 64px; }
    .polaroid-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
  }
  @media (max-width: 600px) {
    .polaroid-grid { grid-template-columns: 1fr; }
    .polaroid { transform: rotate(0) !important; }
  }
</style>
