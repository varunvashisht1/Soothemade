---
const columns = [
  {
    heading: 'Lines',
    links: [
      { href: 'https://notes.soothemade.com', label: 'Soothemade Notes', external: true },
      { href: '/lines#kitchen', label: 'Soothemade Kitchen' },
      { href: '/lines#studio', label: 'Soothemade Studio' },
      { href: '/lines#field', label: 'Soothemade Field' },
    ],
  },
  {
    heading: 'Read',
    links: [
      { href: '/journal', label: 'The journal' },
      { href: '/freebies', label: 'Free printable' },
      { href: '/about', label: 'About the studio' },
    ],
  },
  {
    heading: 'Studio',
    links: [
      { href: '/contact', label: 'Contact' },
      { href: '/policy', label: 'Policy' },
      { href: '/press', label: 'Press' },
      { href: '/newsletter', label: 'Letter' },
    ],
  },
];
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="row">
    <div class="brand-block">
      <div class="logo">Soothemade</div>
      <p>A small studio of slow, considered things. Made for the parts of life no one is photographing.</p>
    </div>
    {columns.map((col) => (
      <div>
        <h4>{col.heading}</h4>
        <ul>
          {col.links.map((l) => (
            <li>
              {l.external
                ? <a href={l.href} class="ext" rel="noopener">{l.label}</a>
                : <a href={l.href}>{l.label}</a>}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="bottom">
    <span>Soothemade · est. {year} · made slowly</span>
    <span>hello@soothemade.com</span>
  </div>
</footer>

<style>
  .foot {
    background: var(--apo-tile-footer);
    color: var(--apo-paper-dim);
    padding: 64px var(--sp-7) 36px;
  }
  .row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }
  h4 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    margin: 0 0 14px;
    color: var(--apo-paper);
    font-weight: 500;
  }
  ul { list-style: none; padding: 0; margin: 0; }
  li { margin-bottom: 8px; font-size: 13px; }
  a { color: var(--apo-paper-dim); transition: color var(--t-fast) var(--ease); }
  a:hover { color: var(--accent-soft); }
  .brand-block .logo {
    font-family: var(--font-script);
    font-size: 36px;
    line-height: 1;
    color: var(--apo-paper);
    margin-bottom: 16px;
    font-weight: 500;
  }
  .brand-block p {
    font-size: 13px;
    max-width: 280px;
    margin: 0;
    line-height: 1.55;
    color: var(--apo-paper-soft);
  }
  .bottom {
    border-top: 1px solid var(--apo-rule-light);
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--apo-paper-faint);
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  @media (max-width: 880px) {
    .foot { padding: 48px var(--sp-5) 28px; }
    .row { grid-template-columns: 1fr 1fr; gap: 28px; }
  }
</style>
