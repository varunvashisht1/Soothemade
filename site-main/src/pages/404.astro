---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import SoftStub from '~/components/SoftStub.astro';
import Footer from '~/components/Footer.astro';
---
<BaseLayout title="Not here — Soothemade" noindex={true}>
  <Nav />
  <SoftStub
    eyebrow="— 404 —"
    heading="There's no page here. Sorry about that."
    body="Either it moved, or it never quite got built, or the address is a typo. The home page is still where you left it."
    backHref="/"
    backLabel="go home →"
  />
  <Footer />
</BaseLayout>
