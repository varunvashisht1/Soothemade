---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---
<BaseLayout title={`${post.data.title}, Soothemade journal`} description={post.data.description}>
  <Nav />
  <header class="essay-head">
    <div class="essay-head-inner">
      <div class="meta">
        <span class="cat">{post.data.category}</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>{fmt(post.data.date)}</span>
        {post.data.readTime && (<><span class="dot" aria-hidden="true">·</span><span>{post.data.readTime}</span></>)}
      </div>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
    </div>
  </header>
  <article class="essay">
    <div class="prose">
      <Content />
    </div>
    <footer class="back">
      <a href="/journal">← back to the journal</a>
    </footer>
  </article>
  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .essay-head {
    background:
      radial-gradient(ellipse 800px 500px at 30% 25%, rgba(184, 134, 42, 0.14), transparent 60%),
      linear-gradient(170deg, var(--apo-hero-1) 0%, var(--apo-hero-2) 60%, var(--apo-hero-3) 100%);
    padding: 96px var(--sp-7) 64px;
    text-align: center;
  }
  .essay-head-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .essay {
    max-width: 680px;
    margin: 0 auto;
    padding: 72px var(--sp-7) 80px;
  }
  .meta {
    font-size: 10.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--apo-paper-faint);
    margin-bottom: 22px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  .cat { color: var(--accent-soft); }
  h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    margin: 0 0 18px;
    line-height: 1.05;
    font-weight: 300;
    letter-spacing: var(--ls-tight);
    color: var(--apo-paper);
  }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--apo-paper-dim);
    font-size: 20px;
    margin: 0 auto;
    max-width: 540px;
    line-height: 1.5;
    font-weight: 300;
  }
  .prose {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.75;
    color: var(--apo-paper);
  }
  .prose :global(p) { margin: 0 0 22px; }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 26px;
    margin: 36px 0 16px;
    font-weight: 500;
  }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 22px 28px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(em) { font-style: italic; color: var(--accent-soft); }
  .prose :global(a) {
    color: var(--accent-soft);
    border-bottom: 1px solid var(--apo-rule-strong);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent-soft);
    padding-left: 18px;
    margin: 24px 0;
    font-style: italic;
    color: var(--apo-paper-dim);
  }
  .back {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--apo-rule-light);
    text-align: center;
  }
  .back a {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--apo-paper);
    border-bottom: 1px solid var(--apo-rule-strong);
    padding-bottom: 1px;
  }
  .back a:hover { color: var(--accent-soft); border-color: var(--accent-soft); }

  @media (max-width: 880px) {
    .essay-head { padding: 64px var(--sp-5) 48px; }
    .essay { padding: 56px var(--sp-5); }
    h1 { font-size: 36px; }
    .lede { font-size: 17px; }
    .prose { font-size: 17px; }
  }
</style>
