---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

const posts = (await getCollection('journal')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---
<BaseLayout
  title="Journal, Soothemade"
  description="Short letters from the studio. Slowness, pace, the unphotographed life."
>
  <Nav />
  <section class="page-header">
    <div class="page-header-inner">
      <div class="eyebrow">letters from the studio</div>
      <h1>The <em>journal.</em></h1>
      <p class="lede">A short letter, every other Sunday. Specific observations, slow arguments, the occasional free printable. No life-hacks. No tips.</p>
    </div>
  </section>

  <main class="list">
    {posts.map((p) => (
      <article class="entry">
        <div class="meta">
          <span class="cat">{p.data.category}</span>
          <span class="dot" aria-hidden="true">·</span>
          <span class="date">{fmt(p.data.date)}</span>
          {p.data.readTime && (<><span class="dot" aria-hidden="true">·</span><span>{p.data.readTime}</span></>)}
        </div>
        <h2><a href={`/journal/${p.id}`}>{p.data.title}</a></h2>
        <p class="desc">{p.data.description}</p>
        <a class="read" href={`/journal/${p.id}`}>read the letter →</a>
      </article>
    ))}
  </main>

  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .list {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 56px var(--sp-7) 80px;
  }
  .entry {
    padding: 36px 0;
    border-top: 1px solid var(--apo-rule-light);
  }
  .entry:last-child { border-bottom: 1px solid var(--apo-rule-light); }
  .meta {
    font-size: 10.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--apo-paper-faint);
    margin-bottom: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .cat { color: var(--accent-soft); }
  .entry h2 {
    font-family: var(--font-serif);
    font-size: 30px;
    font-weight: 400;
    line-height: 1.15;
    margin: 0 0 10px;
  }
  .entry h2 a { color: var(--apo-paper); }
  .entry h2 a:hover { color: var(--accent-soft); }
  .desc {
    font-size: 16px;
    color: var(--apo-paper-dim);
    line-height: 1.55;
    margin-bottom: 14px;
  }
  .read {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--apo-paper);
    border-bottom: 1px solid var(--apo-rule-strong);
    padding-bottom: 1px;
    font-size: 15px;
  }
  .read:hover { color: var(--accent-soft); border-color: var(--accent-soft); }

  @media (max-width: 880px) {
    .list { padding: 40px var(--sp-5) 64px; }
    .entry h2 { font-size: 24px; }
  }
</style>
