---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';
---
<BaseLayout
  title="Contact — Soothemade"
  description="Email the studio. One small inbox, read by a human."
>
  <Nav />
  <section class="page-header">
    <div class="page-header-inner">
      <div class="eyebrow">— contact —</div>
      <h1>Write to the <em>studio.</em></h1>
    </div>
  </section>
  <article class="contact">
    <div class="body">
      <p>
        The shortest path is email. One inbox, read by a human, replied
        to when there is something to say.
      </p>
      <p class="email">
        <a href="mailto:hello@soothemade.com">hello@soothemade.com</a>
      </p>

      <h2>What we read</h2>
      <ul>
        <li>Notes about a product you used. We keep these and revise from them.</li>
        <li>Questions. We answer most. Some take a while.</li>
        <li>Wholesale inquiries (small batches only — see <a href="/press">press</a>).</li>
        <li>Press requests. Same place.</li>
      </ul>

      <h2>What we don't</h2>
      <ul>
        <li>"Quick collaboration" pitches. (They are never quick.)</li>
        <li>AI-content offers. We make things by hand on purpose.</li>
        <li>Anything that wants a reply in 24 hours.</li>
      </ul>

      <p class="fine">If you wrote and didn't hear back within a week, write again. It's not personal — sometimes a note slides under a stack.</p>
    </div>
  </article>
  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .contact {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 64px var(--sp-7) 96px;
  }
  .body { font-size: 18px; line-height: 1.75; color: var(--apo-paper); }
  .body h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 24px;
    margin: 40px 0 14px;
    font-weight: 400;
  }
  .body p { margin-bottom: 18px; }
  .body ul { margin: 0 0 22px 24px; padding: 0; }
  .body li { margin-bottom: 8px; }
  .body a { color: var(--accent-soft); border-bottom: 1px solid var(--apo-rule-strong); }
  .email {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 30px;
    margin: 28px 0 36px;
  }
  .email a { color: var(--accent-soft); border: none; }
  .fine { font-size: 14px; color: var(--apo-paper-faint); font-style: italic; margin-top: 24px; }
  @media (max-width: 880px) {
    .contact { padding: 48px var(--sp-5) 72px; }
    .body { font-size: 16px; }
    .email { font-size: 24px; }
  }
</style>
