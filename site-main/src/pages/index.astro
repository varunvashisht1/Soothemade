---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Hero from '~/components/Hero.astro';
import LineCards from '~/components/LineCards.astro';
import Manifesto from '~/components/Manifesto.astro';
import JournalRow from '~/components/JournalRow.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

const allPosts = await getCollection('journal');
const featuredJournalPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => ({
    href: `/journal/${p.id}`,
    category: p.data.category ?? 'Letter',
    readTime: p.data.readTime ?? '',
    title: p.data.title,
    blurb: p.data.description,
  }));
---
<BaseLayout
  title="Soothemade — slow, considered things for the quiet parts of life"
  description="Soothemade is a small studio making slow, considered things for the parts of life no one is photographing. Printables, planners, journals, and cards — made by hand."
>
  <Nav variant="overlay" />

  <Hero
    headlinePre="Made for the parts of life"
    headlineAccent="no one is photographing."
    body="A small studio of slow, considered things. Planners, journals, printables, and cards for the seasons that move at the pace of weather, not the pace of work."
    primaryCta={{ href: 'https://notes.soothemade.com', label: 'Visit the first room ↗' }}
    secondaryCta={{ href: '/about', label: 'More about us' }}
    featured={{
      label: '— in the window —',
      name: 'Soothemade Notes',
      blurb: 'for the long, mostly-unphotographed first year of new parenthood. open today.',
    }}
  />

  <section class="about-strip">
    <div class="eyebrow-mark">— about the studio —</div>
    <p>
      Soothemade is a small house with one room finished and a few more
      being built. We make planners, journals, printables, and cards for
      the <em>hours under the foam</em>. The Tuesday with nothing planned.
      The recovery month nobody warned you about.
    </p>
  </section>

  <LineCards />

  <Manifesto
    quote="We make things at the"
    quoteAccent="pace of weather."
    tail="Some weeks something gets finished. Some weeks it doesn't. It evens out the way a season does."
  />

  {featuredJournalPosts.length > 0 && (
    <JournalRow
      posts={featuredJournalPosts}
      title="Three"
      titleAccent="recent notes."
    />
  )}

  <Newsletter />

  <Footer />
</BaseLayout>

<style>
  .about-strip {
    padding: 88px var(--sp-7);
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .about-strip .eyebrow-mark {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 18px;
  }
  .about-strip p {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 auto;
    max-width: 58ch;
    font-weight: 300;
  }
  .about-strip p em {
    font-style: italic;
    color: var(--accent);
  }
  @media (max-width: 880px) {
    .about-strip { padding: 56px var(--sp-5); }
    .about-strip p { font-size: 18px; }
  }
</style>
