---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Hero from '~/components/Hero.astro';
import LineCards from '~/components/LineCards.astro';
import Manifesto from '~/components/Manifesto.astro';
import JournalRow from '~/components/JournalRow.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

const allPosts = await getCollection('journal');
const featuredJournalPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => ({
    href: `/journal/${p.id}`,
    category: p.data.category ?? 'letter',
    readTime: p.data.readTime ?? '',
    title: p.data.title,
    blurb: p.data.description,
  }));
---
<BaseLayout
  title="Soothemade — slow, considered things for the quiet parts of life"
  description="Soothemade is a small studio making slow, considered things for the parts of life no one is photographing. Printables, planners, journals, and cards — made by hand."
>
  <Nav />

  <Hero
    headlinePre="Made for the parts of life"
    headlineAccent="no one is photographing."
    body="Soothemade is a small studio of slow, considered things. We make planners, journals, printables, and cards for the seasons that move at the pace of weather, not the pace of work."
    primaryCta={{ href: 'https://notes.soothemade.com', label: 'Visit Soothemade Notes ↗' }}
    secondaryCta={{ href: '/journal', label: 'Read the journal' }}
  />

  <section class="lead rule-top">
    <div class="inner">
      <p>
        There is a kind of time that doesn't show up in any photograph.
        The hour before anyone else is up. The walk you took because you
        couldn't sit still. The Tuesday with nothing planned. The
        recovery month no one warned you about.
      </p>
      <p>
        Most of a life is made of these hours. The ones with the
        photographs in them are the foam on top. We make things — mostly
        paper things — for the hours under the foam.
      </p>
    </div>
  </section>

  <section class="lines-section rule-top">
    <div class="head">
      <div class="eyebrow">— the rooms in the house —</div>
      <h2>A small house. <em>One room open.</em> More being built.</h2>
    </div>
    <LineCards />
    <div class="lines-foot">
      <a href="/lines">See all the rooms →</a>
    </div>
  </section>

  <Manifesto
    quote="We make things at the"
    quoteAccent="pace of weather."
    tail="Some weeks something gets finished. Some weeks it doesn't. It evens out the way a season does."
  />

  {featuredJournalPosts.length > 0 && <JournalRow posts={featuredJournalPosts} title="— Letters from the studio —" />}

  <Newsletter />

  <Footer />
</BaseLayout>

<style>
  .lead {
    padding: 72px var(--sp-7);
    background: var(--surface);
  }
  .inner {
    max-width: var(--container-narrow);
    margin: 0 auto;
    font-family: var(--font-serif);
    font-size: 21px;
    line-height: 1.55;
    color: var(--ink);
    text-align: center;
  }
  .inner p { margin: 0 0 22px; font-weight: 300; }
  .inner p:last-child { margin-bottom: 0; }

  .lines-section { padding-bottom: 32px; }
  .lines-section .head {
    text-align: center;
    padding: 64px var(--sp-7) 0;
  }
  .lines-section h2 {
    font-family: var(--font-serif);
    font-size: 36px;
    margin: 14px 0 8px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.15;
  }
  .lines-section h2 em { font-style: italic; color: var(--accent); }

  .lines-foot {
    text-align: center;
    padding: 0 var(--sp-7) 56px;
  }
  .lines-foot a {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    font-size: 16px;
  }
  .lines-foot a:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 880px) {
    .lead { padding: 48px var(--sp-5); }
    .inner { font-size: 18px; }
    .lines-section .head { padding: 48px var(--sp-5) 0; }
    .lines-section h2 { font-size: 28px; }
  }
</style>
