---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Hero from '~/components/Hero.astro';
import LineCards from '~/components/LineCards.astro';
import Manifesto from '~/components/Manifesto.astro';
import JournalRow from '~/components/JournalRow.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

const allPosts = await getCollection('journal');
const featuredJournalPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((p) => ({
    href: `/journal/${p.id}`,
    category: p.data.category ?? 'Letter',
    readTime: p.data.readTime ?? '',
    title: p.data.title,
    blurb: p.data.description,
  }));
---
<BaseLayout
  title="Soothemade — slow, considered things for the quiet parts of life"
  description="Soothemade is a small studio making slow, considered things for the parts of life no one is photographing. Printables, planners, journals, and cards — made by hand."
>
  <Nav variant="overlay" />

  <Hero
    headlinePre="Made for the parts of life"
    headlineAccent="no one is photographing."
    body="A small studio of slow, considered things. Planners, journals, printables, and cards for the seasons that move at the pace of weather, not the pace of work."
    primaryCta={{ href: 'https://notes.soothemade.com', label: 'Visit the first room ↗' }}
    secondaryCta={{ href: '/about', label: 'More about us' }}
    featured={{
      label: '— in the window —',
      name: 'Soothemade Notes',
      blurb: 'for the long, mostly-unphotographed first year of new parenthood. open today.',
    }}
  />

  <section class="dear-stranger">
    <div class="eyebrow-mark">— Spring · MMXXVI —</div>
    <p class="salutation">Dear stranger,</p>
    <div class="letter-body">
      <p>
        Thank you for finding us. This is a small studio. There is
        not very much here on purpose. We make slow, considered things,
        planners, journals, printables, and cards, for the seasons
        that move at the pace of weather, not the pace of work.
      </p>
      <p>
        The first room is open. Three more are being built, slowly,
        by the same hands. We make one thing at a time. We finish it.
        We make the next one. Some weeks something ships. Some weeks
        it doesn’t. It evens out the way a season does.
      </p>
      <p>
        We make these things for the <em>hours under the foam</em>.
        The Tuesday with nothing planned. The recovery month nobody
        warned you about. The hour before anyone else is up. Most of
        a life is made of those hours.
      </p>
    </div>
    <div class="signoff">
      <p class="with-care">— with care,</p>
      <p class="signature">the studio</p>
    </div>
  </section>

  <LineCards />

  <Manifesto
    quote="We make things at the"
    quoteAccent="pace of weather."
    tail="Some weeks something gets finished. Some weeks it doesn't. It evens out the way a season does."
  />

  {featuredJournalPosts.length > 0 && (
    <JournalRow
      posts={featuredJournalPosts}
      title="Three"
      titleAccent="recent notes."
    />
  )}

  <Newsletter />

  <Footer />
</BaseLayout>

<style>
  /* "Dear stranger" — a candlelit warm tile between the hero
     and the rooms. Narrow column, intimate, dark gradient bg. */
  .dear-stranger {
    position: relative;
    padding: 112px var(--sp-7) 104px;
    background:
      radial-gradient(ellipse 800px 500px at 30% 25%, rgba(184, 134, 42, 0.14), transparent 60%),
      linear-gradient(180deg, var(--apo-tile-letter-1) 0%, var(--apo-tile-letter-2) 60%, var(--apo-tile-letter-3) 100%);
    color: var(--apo-paper);
    overflow: hidden;
  }
  .dear-stranger > * { position: relative; z-index: 1; max-width: 620px; margin-left: auto; margin-right: auto; }
  .dear-stranger .eyebrow-mark {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-soft);
    margin-bottom: 32px;
    text-align: center;
  }
  .dear-stranger .salutation {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 32px;
    line-height: 1.2;
    color: var(--apo-paper);
    margin: 0 0 28px;
    font-weight: 300;
  }
  .dear-stranger .letter-body p {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.75;
    color: var(--apo-paper-dim);
    margin: 0 0 22px;
    font-weight: 300;
  }
  .dear-stranger .letter-body p:last-child { margin-bottom: 0; }
  .dear-stranger .letter-body em {
    font-style: italic;
    color: var(--accent-soft);
  }
  .dear-stranger .signoff { margin-top: 40px; }
  .dear-stranger .with-care {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--apo-paper-soft);
    margin: 0 0 4px;
    font-weight: 300;
  }
  .dear-stranger .signature {
    font-family: var(--font-script);
    font-size: 42px;
    line-height: 1;
    color: var(--apo-paper);
    margin: 0;
    font-weight: 500;
  }
  @media (max-width: 880px) {
    .dear-stranger { padding: 72px var(--sp-5); }
    .dear-stranger .salutation { font-size: 26px; }
    .dear-stranger .letter-body p { font-size: 16.5px; }
    .dear-stranger .signature { font-size: 34px; }
  }
</style>
