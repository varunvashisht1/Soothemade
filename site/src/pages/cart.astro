---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import SoftStub from '~/components/SoftStub.astro';
import Footer from '~/components/Footer.astro';
---
<BaseLayout title="Cart — Soothemade Notes" description="Your cart." noindex={true}>
  <Nav />
  <SoftStub
    eyebrow="— the cart —"
    heading="Checkout opens shortly."
    body="For now, each product links out to Etsy or Gumroad for purchase. Direct checkout (with magic-link re-download and a single basket for multiple items) is the next milestone."
    backHref="/shop"
    backLabel="back to the catalog →"
  />
  <Footer />
</BaseLayout>
