---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import ProductCard from '~/components/ProductCard.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';
import { coverFor } from '~/lib/cover-image';

const products = (await getCollection('products')).sort(
  (a, b) => (a.data.featuredOrder ?? 999) - (b.data.featuredOrder ?? 999),
);

const url = new URL(Astro.request.url);
const activeCategory = url.searchParams.get('cat');

const categories = [
  { slug: null, label: 'All' },
  { slug: 'pregnancy', label: 'Pregnancy' },
  { slug: 'postpartum', label: 'Postpartum' },
  { slug: 'recovery', label: 'Recovery' },
  { slug: 'mental-health', label: 'Mental health' },
  { slug: 'partner', label: 'For the partner' },
  { slug: 'early-years', label: '0–3 years' },
  { slug: 'family', label: 'Family' },
];

const filtered = activeCategory
  ? products.filter((p) => p.data.category === activeCategory)
  : products;
---
<BaseLayout
  title="The catalog — Soothemade Notes"
  description="The full Soothemade Notes catalog of printables, planners, and cards for the unphotographed parts of new parenthood."
>
  <Nav />

  <header class="shop-header rule-bottom">
    <div class="eyebrow">— the catalog —</div>
    <h1>Everything in the shop.</h1>
    <p>Made slowly, in plain language, for the unphotographed days. Currently {products.length} items, with more on the way each month.</p>

    <form class="search-row" id="search-form" role="search" autocomplete="off">
      <label for="q" class="search-label">Looking for something specific?</label>
      <input
        id="q"
        name="q"
        type="search"
        inputmode="search"
        placeholder="e.g. I'm scared about going back to work"
        maxlength="200"
        spellcheck="false"
      />
      <button type="submit" class="search-go" aria-label="Search the catalog">Search</button>
    </form>
  </header>

  <nav class="filter-row rule-bottom" id="filter-row" aria-label="Category filter">
    {categories.map((c) => (
      <a
        href={c.slug ? `/shop?cat=${c.slug}` : '/shop'}
        class:list={['chip', { active: activeCategory === c.slug || (activeCategory === null && c.slug === null) }]}
      >
        {c.label}
      </a>
    ))}
  </nav>

  <section id="search-results" class="search-results" hidden></section>

  {filtered.length === 0 ? (
    <p class="empty" id="catalog-empty">No items in this category yet — check back soon.</p>
  ) : (
    <section class="grid" id="catalog-grid">
      {filtered.map((p) => (
        <ProductCard
          href={`/shop/${p.id}`}
          label={p.data.heroLabel}
          meta={p.data.specs}
          tagline={p.data.tagline}
          price={`$${p.data.price}`}
          code={p.data.code}
          coverImage={coverFor(p.data.code)}
          glyph={p.data.glyph}
        />
      ))}
    </section>
  )}

  <Newsletter />
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('search-form') as HTMLFormElement | null;
  const input = document.getElementById('q') as HTMLInputElement | null;
  const results = document.getElementById('search-results') as HTMLElement | null;
  const grid = document.getElementById('catalog-grid');
  const empty = document.getElementById('catalog-empty');
  const filterRow = document.getElementById('filter-row');

  if (form && input && results) {
    let lastQ = '';

    const escape = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[c] as string));

    const showCatalog = () => {
      results.hidden = true;
      results.innerHTML = '';
      if (grid) (grid as HTMLElement).hidden = false;
      if (empty) (empty as HTMLElement).hidden = false;
      if (filterRow) (filterRow as HTMLElement).hidden = false;
    };

    const hideCatalog = () => {
      if (grid) (grid as HTMLElement).hidden = true;
      if (empty) (empty as HTMLElement).hidden = true;
      if (filterRow) (filterRow as HTMLElement).hidden = true;
      results.hidden = false;
    };

    const renderHits = (
      q: string,
      hits: Array<{ code: string; title: string; slug: string; summary: string; score: number }>,
    ) => {
      if (hits.length === 0) {
        results.innerHTML = `
          <div class="search-empty">
            <p class="search-empty-title">Nothing in the catalog matches "${escape(q)}".</p>
            <p class="search-empty-sub">Try a phrase like "I can't sleep" or "back to work".</p>
            <button type="button" class="search-clear" data-clear>Back to the catalog</button>
          </div>`;
      } else {
        const list = hits
          .map(
            (h) => `
            <a class="search-hit" href="/shop/${escape(h.slug)}">
              <div class="hit-code">${escape(h.code)}</div>
              <div class="hit-body">
                <div class="hit-title">${escape(h.title)}</div>
                <div class="hit-summary">${escape(h.summary)}</div>
              </div>
            </a>`,
          )
          .join('');
        results.innerHTML = `
          <div class="search-meta">
            <span>${hits.length} of the closest matches for "${escape(q)}".</span>
            <button type="button" class="search-clear" data-clear>Clear</button>
          </div>
          <div class="search-list">${list}</div>`;
      }
      results.querySelector('[data-clear]')?.addEventListener('click', () => {
        input.value = '';
        lastQ = '';
        showCatalog();
        input.focus();
      });
    };

    const runSearch = async (q: string) => {
      const trimmed = q.trim();
      if (!trimmed) {
        showCatalog();
        return;
      }
      if (trimmed === lastQ) return;
      lastQ = trimmed;
      hideCatalog();
      results.innerHTML = `<p class="search-loading">Looking…</p>`;
      try {
        const r = await fetch(`/api/search?q=${encodeURIComponent(trimmed)}`);
        const data = (await r.json()) as { ok: boolean; hits?: unknown[] };
        if (!data.ok) {
          results.innerHTML = `<p class="search-loading">Something went wrong. Try again in a moment.</p>`;
          return;
        }
        renderHits(trimmed, (data.hits ?? []) as Array<{
          code: string;
          title: string;
          slug: string;
          summary: string;
          score: number;
        }>);
      } catch {
        results.innerHTML = `<p class="search-loading">Couldn't reach the catalog. Check your connection.</p>`;
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      runSearch(input.value);
    });

    input.addEventListener('input', () => {
      if (input.value.trim() === '' && lastQ !== '') {
        lastQ = '';
        showCatalog();
      }
    });
  }
</script>

<style>
  .shop-header {
    padding: 96px var(--sp-7) 64px;
    text-align: center;
    background:
      radial-gradient(ellipse 700px 400px at 50% 30%, rgba(214, 138, 114, 0.14), transparent 60%),
      linear-gradient(170deg, var(--n-hero-1) 0%, var(--n-hero-2) 60%, var(--n-hero-3) 100%);
    color: var(--ink);
  }
  .shop-header .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }
  .shop-header h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-4xl);
    margin: 16px 0 18px;
    font-weight: 300;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }
  .shop-header p {
    max-width: 540px;
    margin: 0 auto;
    color: var(--n-paper-dim);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    line-height: 1.5;
    font-weight: 300;
  }
  .filter-row {
    padding: 24px var(--sp-7);
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    background: var(--n-cats-1);
    border-top: 1px solid var(--n-rule-light);
    border-bottom: 1px solid var(--n-rule-light);
  }
  .chip {
    border: 1px solid var(--n-rule-strong);
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    font-size: 12.5px;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    transition: all var(--t-fast) var(--ease);
  }
  .chip:hover { border-color: var(--accent-soft); color: var(--accent-soft); }
  .chip.active { background: var(--accent); color: var(--n-news-1); border-color: var(--accent); }
  .grid {
    padding: 72px var(--sp-7) 80px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    background:
      radial-gradient(ellipse 900px 600px at 80% 20%, rgba(168, 184, 138, 0.08), transparent 60%),
      linear-gradient(170deg, var(--n-prods-1) 0%, var(--n-prods-2) 60%, var(--n-prods-3) 100%);
  }
  .empty {
    text-align: center;
    padding: 96px var(--sp-5);
    color: var(--n-paper-dim);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    background: linear-gradient(170deg, var(--n-prods-1) 0%, var(--n-prods-2) 60%, var(--n-prods-3) 100%);
  }
  @media (max-width: 1100px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 880px) {
    .shop-header { padding: 56px var(--sp-5) 40px; }
    .shop-header h1 { font-size: 40px; }
    .grid { padding: 32px var(--sp-5) 48px; }
    .filter-row { padding: 18px var(--sp-5); }
  }

  .search-row {
    display: flex;
    gap: 8px;
    max-width: 540px;
    margin: 28px auto 0;
    align-items: stretch;
  }
  .search-label {
    position: absolute;
    width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .search-row input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--n-rule-strong);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--ink);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
  }
  .search-row input::placeholder { color: var(--n-paper-faint); }
  .search-row input:focus {
    outline: none;
    border-color: var(--accent-soft);
  }
  .search-go {
    border: 1px solid var(--n-rule-strong);
    background: transparent;
    color: var(--ink);
    padding: 0 18px;
    border-radius: var(--radius-pill);
    font-size: 13px;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--t-fast) var(--ease);
  }
  .search-go:hover { border-color: var(--accent-soft); color: var(--accent-soft); }

  .search-results {
    padding: 56px var(--sp-7) 80px;
    background: linear-gradient(170deg, var(--n-prods-1) 0%, var(--n-prods-2) 60%, var(--n-prods-3) 100%);
  }
  .search-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--n-paper-dim);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    margin-bottom: 20px;
  }
  .search-clear {
    background: transparent;
    border: none;
    color: var(--accent-soft);
    cursor: pointer;
    font: inherit;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    font-size: 12px;
  }
  .search-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .search-hit {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 18px;
    padding: 24px 0;
    border-top: 1px solid var(--n-rule-light);
    color: var(--ink);
    transition: background var(--t-fast) var(--ease);
  }
  .search-hit:last-child { border-bottom: 1px solid var(--n-rule-light); }
  .search-hit:hover { background: rgba(235, 226, 200, 0.04); }
  .hit-code {
    font-family: var(--font-mono, var(--font-sans));
    font-size: 12px;
    letter-spacing: var(--ls-wide);
    color: var(--n-paper-faint);
    padding-top: 6px;
  }
  .hit-title {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.3;
    margin-bottom: 6px;
    color: var(--ink);
  }
  .hit-summary {
    color: var(--n-paper-dim);
    font-size: 14.5px;
    line-height: 1.55;
  }
  .search-empty {
    text-align: center;
    padding: 56px 0;
  }
  .search-empty-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    color: var(--ink);
  }
  .search-empty-sub {
    color: var(--n-paper-dim);
    font-size: 14.5px;
    margin: 10px 0 24px;
  }
  .search-loading {
    color: var(--n-paper-dim);
    font-family: var(--font-serif);
    font-style: italic;
    text-align: center;
    padding: 32px 0;
  }
  @media (max-width: 880px) {
    .search-row { padding: 0 var(--sp-5); }
    .search-results { padding: 24px var(--sp-5) 40px; }
  }
</style>
