---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import ProductCard from '~/components/ProductCard.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';

export const prerender = true;

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const all = await getCollection('products');
const crossSell = (product.data.crossSell ?? [])
  .map((slug) => all.find((p) => p.id === slug))
  .filter((p): p is (typeof all)[number] => Boolean(p));

const ymyl = product.data.ymyl;
---
<BaseLayout
  title={`${product.data.title} — Soothemade Notes`}
  description={product.data.summary}
>
  <Nav />

  <article class="product">
    <div class="crumbs">
      <a href="/shop">← back to the catalog</a>
    </div>

    <header class="hero rule-bottom">
      <div class="hero-text">
        <div class="code">{product.data.code} · {product.data.specs}</div>
        <h1>{product.data.title}</h1>
        <p class="tagline">{product.data.summary}</p>
        <div class="actions">
          {product.data.etsyUrl ? (
            <a class="btn btn-primary" href={product.data.etsyUrl} rel="nofollow noopener" target="_blank">
              Buy on Etsy · ${product.data.price}
            </a>
          ) : (
            <a class="btn btn-primary" href="#hold" aria-disabled="true">
              Buy on Etsy · ${product.data.price}
            </a>
          )}
          {product.data.gumroadUrl && (
            <a class="btn btn-secondary" href={product.data.gumroadUrl} rel="nofollow noopener" target="_blank">
              Buy on Gumroad
            </a>
          )}
          {product.data.badge && (<span class="badge">{product.data.badge}</span>)}
        </div>
      </div>
      <aside class="hero-art" aria-hidden="true">
        <div class="jar">
          <div class="jar-inner">
            <div class="jar-label" set:html={product.data.heroLabel.replace(/\n/g, '<br/>')} />
            <div class="jar-meta">{product.data.specs}</div>
          </div>
        </div>
      </aside>
    </header>

    {ymyl && (
      <aside class="ymyl">
        <strong>Read before you buy.</strong>
        This product touches subject matter that warrants care.
        It is a tracking and planning tool, <em>not</em> medical advice.
        If you are in crisis, call <a href="tel:988">988</a> or the US Maternal Mental Health Hotline at <a href="tel:18338526262">1-833-852-6262</a> (24/7, free, confidential).
      </aside>
    )}

    <section class="body">
      <Content />
    </section>

    {crossSell.length > 0 && (
      <section class="cross">
        <h2>You might also want —</h2>
        <div class="cross-grid">
          {crossSell.map((p) => (
            <ProductCard
              href={`/shop/${p.id}`}
              label={p.data.heroLabel}
              meta={p.data.specs}
              tagline={p.data.tagline}
              price={`$${p.data.price}`}
              code={p.data.code}
              glyph={p.data.glyph}
            />
          ))}
        </div>
      </section>
    )}
  </article>

  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .product { padding: 0; }
  .crumbs {
    padding: 24px var(--sp-7) 0;
    font-family: var(--font-serif);
    font-style: italic;
  }
  .crumbs a { color: var(--ink-soft); }
  .crumbs a:hover { color: var(--accent); }

  .hero {
    padding: 48px var(--sp-7) 72px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .code {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-4xl);
    margin: 0 0 22px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }
  .tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 21px;
    color: var(--ink-soft);
    margin: 0 0 28px;
    line-height: 1.4;
    max-width: 540px;
  }
  .actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .badge {
    font-size: 11px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }

  /* Jar art */
  .hero-art { display: flex; justify-content: center; align-items: center; }
  .jar {
    background: var(--card);
    border: 1px solid var(--rule-strong);
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3/4;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-align: center;
  }
  .jar-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--card-text);
    line-height: 1.2;
  }
  .jar-meta {
    font-size: 11px;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--card-text-soft);
    border-top: 1px solid var(--card-rule);
    padding-top: 14px;
  }

  .ymyl {
    background: var(--surface-deep);
    color: var(--ink-soft);
    padding: 22px var(--sp-7);
    border-bottom: 1px solid var(--rule);
    font-size: 14px;
    line-height: 1.55;
  }
  .ymyl strong { color: var(--accent); font-weight: 500; }
  .ymyl em { font-style: italic; color: var(--ink); }
  .ymyl a { color: var(--accent); text-decoration: underline; }

  /* Long-form body */
  .body {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px var(--sp-7) 80px;
    color: var(--ink);
    font-size: 17px;
    line-height: 1.7;
  }
  .body :global(h2) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 28px;
    margin: 44px 0 14px;
    font-weight: 500;
    color: var(--ink);
  }
  .body :global(h3) {
    font-family: var(--font-serif);
    font-size: 21px;
    margin: 32px 0 10px;
    font-weight: 500;
  }
  .body :global(p) { margin: 0 0 18px; color: var(--ink); }
  .body :global(ul), .body :global(ol) { margin: 0 0 22px 22px; padding: 0; }
  .body :global(li) { margin-bottom: 8px; }
  .body :global(strong) { color: var(--ink); font-weight: 500; }
  .body :global(em) { font-style: italic; color: var(--accent); }
  .body :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding: 8px 0 8px 18px;
    margin: 22px 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
  }
  .body :global(a) { color: var(--accent); border-bottom: 1px solid var(--rule-strong); }

  /* Cross-sell */
  .cross {
    border-top: 1px solid var(--rule);
    padding: 64px var(--sp-7) 48px;
    background: var(--surface-deep);
  }
  .cross h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 28px;
    margin: 0 0 32px;
    text-align: center;
    color: var(--ink);
    font-weight: 400;
  }
  .cross-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 720px;
    margin: 0 auto;
  }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; padding: 32px var(--sp-5) 48px; gap: 36px; }
    .hero-art { order: -1; }
    .jar { max-width: 260px; }
    h1 { font-size: 40px; }
    .body { padding: 48px var(--sp-5) 64px; font-size: 16px; }
    .cross { padding: 48px var(--sp-5) 32px; }
    .cross-grid { grid-template-columns: 1fr; }
  }
</style>
