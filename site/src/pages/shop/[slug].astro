---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import ProductCard from '~/components/ProductCard.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';
import { coverFor, coverMotif } from '~/lib/cover-image';

export const prerender = true;

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const all = await getCollection('products');
const crossSell = (product.data.crossSell ?? [])
  .map((slug) => all.find((p) => p.id === slug))
  .filter((p): p is (typeof all)[number] => Boolean(p));

const ymyl = product.data.ymyl;
const heroImage = coverFor(product.data.code);
const heroMotif = heroImage ? null : coverMotif(product.data.code);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.data.title,
  description: product.data.summary,
  sku: product.data.code,
  image: new URL(heroImage ?? '/og-default.png', Astro.site).toString(),
  brand: { '@type': 'Brand', name: 'Soothemade' },
  category: product.data.category,
  offers: {
    '@type': 'Offer',
    price: product.data.price,
    priceCurrency: 'USD',
    url: product.data.etsyUrl ?? pageUrl,
    availability: product.data.etsyUrl
      ? 'https://schema.org/InStock'
      : 'https://schema.org/PreOrder',
  },
};
---
<BaseLayout
  title={`${product.data.title} — Soothemade Notes`}
  description={product.data.summary}
>
  <Nav />

  <script type="application/ld+json" set:html={JSON.stringify(productLd)} is:inline />

  <article class="product">
    <div class="crumbs">
      <a href="/shop">← back to the catalog</a>
    </div>

    <header class="hero rule-bottom">
      <div class="hero-text">
        <div class="code">{product.data.code} · {product.data.specs}</div>
        <h1>{product.data.title}</h1>
        <p class="tagline">{product.data.summary}</p>
        <div class="actions">
          {product.data.etsyUrl ? (
            <a class="btn btn-primary" href={product.data.etsyUrl} rel="nofollow noopener" target="_blank">
              Buy on Etsy · ${product.data.price}
            </a>
          ) : (
            <form class="notify" data-code={product.data.code}>
              <span class="notify-label">${product.data.price} · coming soon</span>
              <div class="notify-row">
                <input type="email" name="email" required placeholder="your email" aria-label="Email address" autocomplete="email" />
                <button type="submit" class="btn btn-primary">Email me when it's ready</button>
              </div>
              <p class="notify-status" role="status" aria-live="polite" hidden></p>
            </form>
          )}
          {product.data.gumroadUrl && (
            <a class="btn btn-secondary" href={product.data.gumroadUrl} rel="nofollow noopener" target="_blank">
              Buy on Gumroad
            </a>
          )}
          {product.data.badge && (<span class="badge">{product.data.badge}</span>)}
        </div>
      </div>
      <aside class="hero-art" aria-hidden="true">
        {heroImage ? (
          <div class="hero-image">
            <img src={heroImage} alt={product.data.title} loading="eager" />
          </div>
        ) : (
          <div class="cover-plate">
            <span class="cp-code">{product.data.code}</span>
            <div class="cp-mid">
              <svg class:list={['cp-motif', `tint-${heroMotif!.tint}`]} viewBox="0 0 100 100" set:html={heroMotif!.art} />
              <div class="cp-title" set:html={product.data.heroLabel.replace(/\n/g, '<br/>')} />
            </div>
            <span class="cp-meta">{product.data.specs}</span>
          </div>
        )}
      </aside>
    </header>

    {ymyl && (
      <aside class="ymyl">
        <strong>Read before you buy.</strong>
        This product touches subject matter that warrants care.
        It is a tracking and planning tool, <em>not</em> medical advice.
        If you are in crisis, call <a href="tel:988">988</a> or the US Maternal Mental Health Hotline at <a href="tel:18338526262">1-833-852-6262</a> (24/7, free, confidential).
      </aside>
    )}

    <div class="body-wrap">
      <section class="body">
        <Content />
      </section>
    </div>

    {crossSell.length > 0 && (
      <section class="cross">
        <h2>You might also want —</h2>
        <div class="cross-grid">
          {crossSell.map((p) => (
            <ProductCard
              href={`/shop/${p.id}`}
              label={p.data.heroLabel}
              meta={p.data.specs}
              tagline={p.data.tagline}
              price={`$${p.data.price}`}
              code={p.data.code}
              coverImage={coverFor(p.data.code)}
              glyph={p.data.glyph}
            />
          ))}
        </div>
      </section>
    )}
  </article>

  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .product {
    padding: 0;
    background:
      radial-gradient(ellipse 700px 400px at 25% 30%, rgba(214, 138, 114, 0.12), transparent 60%),
      radial-gradient(ellipse 600px 700px at 80% 75%, rgba(168, 184, 138, 0.10), transparent 60%),
      linear-gradient(170deg, var(--n-hero-1) 0%, var(--n-hero-2) 60%, var(--n-hero-3) 100%);
  }
  .crumbs {
    padding: 32px var(--sp-7) 0;
    font-family: var(--font-serif);
    font-style: italic;
  }
  .crumbs a { color: var(--n-paper-soft); }
  .crumbs a:hover { color: var(--accent-soft); }

  .hero {
    padding: 56px var(--sp-7) 80px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .code {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: var(--fs-4xl);
    margin: 0 0 24px;
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }
  .tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 21px;
    color: var(--n-paper-dim);
    margin: 0 0 30px;
    line-height: 1.5;
    max-width: 540px;
    font-weight: 300;
  }
  .actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .badge {
    font-size: 11px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }

  /* Jar art + lifestyle image */
  .hero-art { display: flex; justify-content: center; align-items: center; }
  .hero-image {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    overflow: hidden;
    border: 1px solid var(--rule);
    background: var(--card);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .cover-plate {
    position: relative;
    background:
      radial-gradient(ellipse 58% 42% at 50% 34%, rgba(255, 253, 247, 0.9), transparent 68%),
      linear-gradient(160deg, #f7f1de 0%, #e2cfa6 50%, #c8a878 100%);
    border: 1px solid var(--rule-strong);
    width: 100%;
    max-width: 340px;
    aspect-ratio: 3/4;
    padding: 30px 26px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    text-align: center;
  }
  .cover-plate::after {
    content: '';
    position: absolute;
    inset: 14px;
    border: 1px solid var(--card-rule);
    pointer-events: none;
  }
  .cp-code {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--card-text-soft);
    padding-top: 8px;
  }
  .cp-mid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .cp-motif { width: 84px; height: 84px; display: block; }
  .cp-motif.tint-terracotta { color: var(--accent); }
  .cp-motif.tint-sage { color: var(--card-text); }
  .cp-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 24px;
    color: var(--card-text);
    line-height: 1.2;
  }
  .cp-meta {
    position: relative;
    z-index: 1;
    font-size: 11px;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--card-text-soft);
    padding-bottom: 8px;
  }

  .ymyl {
    background: linear-gradient(170deg, var(--n-quote-1) 0%, var(--n-quote-2) 100%);
    color: var(--n-paper-dim);
    padding: 28px var(--sp-7);
    border-top: 1px solid var(--n-rule-light);
    border-bottom: 1px solid var(--n-rule-light);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .ymyl strong { color: var(--accent-soft); font-weight: 500; }
  .ymyl em { font-style: italic; color: var(--ink); }
  .ymyl a { color: var(--accent-soft); text-decoration: underline; }

  /* Long-form body */
  .body-wrap {
    background: linear-gradient(170deg, var(--n-letters-1) 0%, var(--n-letters-2) 60%, var(--n-letters-3) 100%);
  }
  .body {
    max-width: 720px;
    margin: 0 auto;
    padding: 88px var(--sp-7) 96px;
    color: var(--ink);
    font-size: 17px;
    line-height: 1.7;
  }
  .body :global(h2) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 28px;
    margin: 44px 0 14px;
    font-weight: 500;
    color: var(--ink);
  }
  .body :global(h3) {
    font-family: var(--font-serif);
    font-size: 21px;
    margin: 32px 0 10px;
    font-weight: 500;
  }
  .body :global(p) { margin: 0 0 18px; color: var(--ink); }
  .body :global(ul), .body :global(ol) { margin: 0 0 22px 22px; padding: 0; }
  .body :global(li) { margin-bottom: 8px; }
  .body :global(strong) { color: var(--ink); font-weight: 500; }
  .body :global(em) { font-style: italic; color: var(--accent-soft); }
  .body :global(blockquote) {
    border-left: 2px solid var(--accent-soft);
    padding: 8px 0 8px 18px;
    margin: 22px 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--n-paper-dim);
  }
  .body :global(a) { color: var(--accent-soft); border-bottom: 1px solid var(--n-rule-strong); }

  /* Cross-sell */
  .cross {
    border-top: 1px solid var(--n-rule-light);
    padding: 88px var(--sp-7) 72px;
    background:
      radial-gradient(ellipse 800px 400px at 50% 0%, rgba(168, 184, 138, 0.10), transparent 70%),
      linear-gradient(170deg, var(--n-prods-1) 0%, var(--n-prods-2) 60%, var(--n-prods-3) 100%);
  }
  .cross h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 30px;
    margin: 0 0 36px;
    text-align: center;
    color: var(--ink);
    font-weight: 300;
  }
  .cross-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 720px;
    margin: 0 auto;
  }

  /* Notify-me capture (shown when there is no live store URL yet) */
  .notify { display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 480px; }
  .notify-label {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--accent);
  }
  .notify-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .notify-row input {
    flex: 1;
    min-width: 200px;
    padding: 12px 16px;
    border: 1px solid var(--n-rule-strong);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--ink);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
  }
  .notify-row input::placeholder { color: var(--n-paper-faint); }
  .notify-row input:focus { outline: none; border-color: var(--accent-soft); }
  .notify-status {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--n-paper-dim);
    margin: 0;
  }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; padding: 32px var(--sp-5) 48px; gap: 36px; }
    .hero-art { order: -1; }
    .cover-plate { max-width: 280px; }
    h1 { font-size: 40px; }
    .body { padding: 48px var(--sp-5) 64px; font-size: 16px; }
    .cross { padding: 48px var(--sp-5) 32px; }
    .cross-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll('form.notify').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    const status = form.querySelector('.notify-status') as HTMLElement;
    const row = form.querySelector('.notify-row') as HTMLElement;
    const input = form.querySelector('input[name="email"]') as HTMLInputElement;
    const btn = form.querySelector('button') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;
      const code = form.getAttribute('data-code') ?? '';
      btn.disabled = true;
      const show = (msg: string) => { status.hidden = false; status.textContent = msg; };
      try {
        const r = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: `notify:${code}` }),
        });
        const data = (await r.json()) as { ok: boolean; error?: string };
        if (data.ok) {
          row.hidden = true;
          show("Thank you. We'll email you the moment it's for sale.");
        } else if (data.error === 'rate_limited') {
          show("You're already on the list — we'll be in touch.");
          btn.disabled = false;
        } else {
          show("That email didn't look right. Mind trying again?");
          btn.disabled = false;
        }
      } catch {
        show("Couldn't reach us just now. Try again in a moment.");
        btn.disabled = false;
      }
    });
  });
</script>
