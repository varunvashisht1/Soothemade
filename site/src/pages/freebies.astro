---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import SoftStub from '~/components/SoftStub.astro';
import Newsletter from '~/components/Newsletter.astro';
import Footer from '~/components/Footer.astro';
---
<BaseLayout
  title="Free printables, Soothemade Notes"
  description="Free printable samples from the Soothemade Notes catalog. New ones arrive in the newsletter."
>
  <Nav />
  <SoftStub
    eyebrow="free printables"
    heading="The first freebie is on its way."
    body="The shop is just opening. Subscribe to the letter below and the first free printable lands in your inbox within a few days."
    backHref="/shop"
    backLabel="see the catalog →"
  />
  <Newsletter
    heading="Subscribe and get the first"
    headingAccent="freebie"
    body="One short letter every other Sunday. A free printable in every issue. We never share addresses."
  />
  <Footer />
</BaseLayout>
