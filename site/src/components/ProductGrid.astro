---
import ProductCard from './ProductCard.astro';

interface Product {
  slug: string;
  label: string;
  meta: string;
  tagline: string;
  price: string;
  code: string;
  glyph?: Parameters<typeof ProductCard>[0]['glyph'];
}

interface Props {
  title?: string;
  seeAllHref?: string;
  seeAllLabel?: string;
  products: Product[];
}

const {
  title = '— From the catalog —',
  seeAllHref = '/shop',
  seeAllLabel = 'see all twenty-one →',
  products,
} = Astro.props;
---
<section class="shop">
  <div class="title-row">
    <h2>{title}</h2>
    <a class="see-all" href={seeAllHref}>{seeAllLabel}</a>
  </div>
  <div class="grid">
    {products.map((p) => (
      <ProductCard
        href={`/shop/${p.slug}`}
        label={p.label}
        meta={p.meta}
        tagline={p.tagline}
        price={p.price}
        code={p.code}
        glyph={p.glyph}
      />
    ))}
  </div>
</section>

<style>
  .shop { padding: 64px var(--sp-7) 48px; }
  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 40px;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  h2 {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 32px;
    margin: 0;
    color: var(--ink);
    font-weight: 400;
  }
  .see-all {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    font-size: 15px;
  }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  @media (max-width: 1100px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 880px)  { .shop { padding: 48px var(--sp-5) 32px; } }
</style>
