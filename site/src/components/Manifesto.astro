---
interface Props { quote: string; quoteAccent?: string; tail?: string; cite?: string; }
const {
  quote,
  quoteAccent,
  tail,
  cite = 'the soothemade promise',
} = Astro.props;
---
<section class="manifesto">
  <blockquote>
    {quote}{quoteAccent && (<>{' '}<em>{quoteAccent}</em></>)}{tail && (<>{' '}{tail}</>)}
  </blockquote>
  <cite>{cite}</cite>
</section>

<style>
  .manifesto {
    padding: 120px var(--sp-7);
    text-align: center;
    color: var(--ink);
    background:
      radial-gradient(ellipse 700px 400px at 50% 30%, rgba(226, 167, 143, 0.22), transparent 65%),
      linear-gradient(170deg, var(--n-quote-1) 0%, var(--n-quote-2) 60%, var(--n-quote-3) 100%);
    position: relative;
    overflow: hidden;
  }
  blockquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 38px;
    line-height: 1.28;
    margin: 0 auto;
    max-width: 780px;
    color: var(--ink);
    font-weight: 300;
    position: relative;
    z-index: 1;
  }
  blockquote em { color: var(--accent-soft); font-style: italic; }
  cite {
    display: block;
    font-style: normal;
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--n-paper-soft);
    margin-top: 30px;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 880px) {
    .manifesto { padding: 80px var(--sp-5); }
    blockquote { font-size: 26px; }
  }
</style>
