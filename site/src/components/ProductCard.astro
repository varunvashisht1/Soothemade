---
import { coverMotif } from '~/lib/cover-image';

interface Props {
  href: string;
  /** Cover title text — multi-line allowed via "\n". */
  label: string;
  /** Small spec line (e.g. "80 cards · 0–3 yrs"). */
  meta: string;
  /** Tagline shown below the cover, in the brand voice. */
  tagline: string;
  /** Display price (e.g. "$14"). */
  price: string;
  /** Product code (e.g. "P09"). */
  code: string;
  /** Optional cover image URL — if provided, displayed instead of the label cover. */
  coverImage?: string;
}
const { href, label, meta, tagline, price, code, coverImage } = Astro.props;
const motif = coverImage ? null : coverMotif(code);
---
<a class="pcard" href={href}>
  {coverImage ? (
    <div class="frame frame--image">
      <img src={coverImage} alt={label.replace(/\n/g, ' ')} loading="lazy" />
    </div>
  ) : (
    <div class="frame frame--label">
      <div class="cover-code">{code}</div>
      <div class="cover-mid">
        <svg class:list={['cover-motif', `tint-${motif!.tint}`]} viewBox="0 0 100 100" aria-hidden="true" set:html={motif!.art} />
        <div class="cover-title" set:html={label.replace(/\n/g, '<br/>')} />
      </div>
      <div class="cover-foot">{meta}</div>
    </div>
  )}
  <h3>{tagline}</h3>
  <div class="meta-row">
    <span>{price}</span>
    <span>{code}</span>
  </div>
</a>

<style>
  .pcard { color: var(--ink); display: block; }
  .frame {
    aspect-ratio: 3/4;
    background: var(--card);
    border: 1px solid var(--rule);
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 22px 18px;
    transition: border-color var(--t-fast) var(--ease), transform var(--t-base) var(--ease);
  }
  .frame--image {
    padding: 0;
  }
  .frame--image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .pcard:hover .frame { border-color: var(--accent); transform: translateY(-2px); }

  /* "Apothecary label" cover for products without a lifestyle photo.
     Warm paper-at-dusk gradient + a soft light bloom behind the mark,
     so it reads like a sky on paper rather than a flat cream card. */
  .frame--label {
    align-items: center;
    text-align: center;
    padding: 14px;
    background:
      radial-gradient(ellipse 62% 46% at 50% 36%, rgba(255, 252, 244, 0.6), transparent 72%),
      linear-gradient(158deg, #f4eedc 0%, #eaddc1 56%, #dccba8 100%);
  }
  .frame--label::after {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid var(--card-rule);
    pointer-events: none;
  }
  .cover-code {
    position: relative;
    z-index: 1;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--card-text-soft);
    padding-top: 6px;
  }
  .cover-mid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .cover-motif { width: 58px; height: 58px; display: block; }
  .cover-motif.tint-terracotta { color: var(--accent); }
  .cover-motif.tint-sage { color: var(--card-text); }
  .pcard:hover .cover-motif.tint-terracotta { color: var(--accent-soft); }
  .cover-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 17px;
    color: var(--card-text);
    line-height: 1.25;
    max-width: 80%;
  }
  .cover-foot {
    position: relative;
    z-index: 1;
    font-size: 9.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--card-text-soft);
    padding-bottom: 6px;
  }
  h3 {
    font-family: var(--font-serif);
    font-size: 16px;
    margin: 0 0 4px;
    font-weight: 500;
    line-height: 1.25;
  }
  .meta-row {
    font-size: 11px;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    justify-content: space-between;
  }
</style>
