---
interface Props {
  eyebrow: string;
  heading: string;
  body: string;
  backHref?: string;
  backLabel?: string;
}
const {
  eyebrow,
  heading,
  body,
  backHref = '/shop',
  backLabel = 'visit the catalog instead →',
} = Astro.props;
---
<section class="stub">
  <div class="stub-inner">
    <div class="eyebrow">{eyebrow}</div>
    <h1>{heading}</h1>
    <p>{body}</p>
    <a class="back" href={backHref}>{backLabel}</a>
  </div>
</section>

<style>
  .stub {
    background:
      radial-gradient(ellipse 800px 500px at 25% 30%, rgba(214, 138, 114, 0.14), transparent 60%),
      radial-gradient(ellipse 600px 700px at 80% 75%, rgba(168, 184, 138, 0.12), transparent 60%),
      linear-gradient(170deg, var(--n-hero-1) 0%, var(--n-hero-2) 60%, var(--n-hero-3) 100%);
  }
  .stub-inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 140px var(--sp-7) 160px;
    text-align: center;
  }
  .eyebrow {
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent-soft);
    margin-bottom: 22px;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    margin: 0 0 24px;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--ink);
  }
  p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    color: var(--n-paper-dim);
    line-height: 1.55;
    margin: 0 0 36px;
    font-weight: 300;
  }
  .back {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    border-bottom: 1px solid var(--n-rule-strong);
    padding-bottom: 2px;
    font-size: 17px;
  }
  .back:hover { color: var(--accent-soft); border-color: var(--accent-soft); }
  @media (max-width: 880px) {
    .stub-inner { padding: 96px var(--sp-5) 112px; }
    h1 { font-size: 34px; }
    p { font-size: 17px; }
  }
</style>
