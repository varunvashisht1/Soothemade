---
interface Props {
  size?: number;
  rotate?: number;
  class?: string;
  style?: string;
}
const { size = 60, rotate = 0, class: className = '', style = '' } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 60 60"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  class={className}
  style={`transform: rotate(${rotate}deg); ${style}`}
  aria-hidden="true"
>
  <path d="M10 50 Q 30 10, 50 50 Q 30 30, 10 50 Z M30 14 L 30 48" stroke-linecap="round" />
</svg>
