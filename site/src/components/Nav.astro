---
const links = [
  { href: '/shop', label: 'Catalog' },
  { href: '/journal', label: 'Journal' },
  { href: '/freebies', label: 'Free Printables' },
  { href: '/about', label: 'About' },
];
---
<nav class="topnav rule-bottom">
  <a href="/" class="logo" aria-label="Soothemade Notes — home">
    <svg viewBox="370 125 60 95" fill="none" width="20" height="32" aria-hidden="true">
      <path d="M 400 215 Q 397 175 401 130" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
      <ellipse cx="386" cy="190" rx="11" ry="4" fill="currentColor" transform="rotate(-45 386 190)"/>
      <ellipse cx="414" cy="160" rx="11" ry="4" fill="currentColor" transform="rotate(45 414 160)"/>
    </svg>
    <span>Soothemade <em>Notes</em></span>
  </a>
  <div class="links">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
  <a href="/cart" class="basket">Basket · 0</a>
</nav>

<style>
  .topnav {
    padding: var(--sp-5) var(--sp-7);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-5);
  }
  .logo {
    font-family: var(--font-script);
    font-size: 30px;
    color: var(--ink);
    font-weight: 500;
    display: flex;
    align-items: baseline;
    gap: 10px;
    line-height: 1;
  }
  .logo svg { color: var(--sage); align-self: center; }
  .logo em {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 21px;
    color: var(--accent);
    font-weight: 400;
    margin-left: 4px;
  }
  .links {
    display: flex;
    gap: 30px;
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .links a { color: var(--ink-soft); transition: color var(--t-fast) var(--ease); }
  .links a:hover { color: var(--accent); }
  .basket {
    border: 1px solid var(--rule-strong);
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    font-size: 11.5px;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    transition: border-color var(--t-fast) var(--ease);
  }
  .basket:hover { border-color: var(--accent); }
  @media (max-width: 880px) {
    .topnav { flex-wrap: wrap; padding: var(--sp-4) var(--sp-5); }
    .links { order: 3; flex-basis: 100%; justify-content: center; }
  }
</style>
